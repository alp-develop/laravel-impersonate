{
    "name": "alp-develop/laravel-impersonate",
    "description": "Secure user impersonation for Laravel applications",
    "keywords": ["laravel", "impersonate", "impersonation", "user-switching"],
    "license": "MIT",
    "authors": [
        {
            "name": "alp-develop",
            "homepage": "https://github.com/alp-develop"
        }
    ],
    "require": {
        "php": "^8.1",
        "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "AlpDevelop\\LaravelImpersonate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "AlpDevelop\\LaravelImpersonate\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AlpDevelop\\LaravelImpersonate\\ImpersonateServiceProvider"
            ],
            "aliases": {
                "Impersonate": "AlpDevelop\\LaravelImpersonate\\Facades\\Impersonate"
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "support": {
        "issues": "https://github.com/alp-develop/laravel-impersonate/issues",
        "source": "https://github.com/alp-develop/laravel-impersonate"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
